#include<iostream>
#include<fstream>
using namespace std;

class Student{

    int roll;
    string name;
    float marks;

public:

    Student(int r=0,string n="",float m=0){
        roll=r;
        name=n;
        marks=m;
    }

    ~Student(){
        cout<<"Destroying student ..."<<endl;
    }

    void write(ofstream &f){
        f<<roll<<" "<<name<<" "<<marks<<endl;
    }
};

int main(){

    Student s[3] = {
        Student(1,"Amit",80),
        Student(2,"Neha",90),
        Student(3,"Ravi",75)
    };

    ofstream fout("students.txt");

    for(int i=0;i<3;i++)
        s[i].write(fout);

    fout.close();

    ifstream fin("students.txt");

    int r; string n; float m;

    while(fin>>r>>n>>m)
        cout<<r<<" "<<n<<" "<<m<<endl;

}





