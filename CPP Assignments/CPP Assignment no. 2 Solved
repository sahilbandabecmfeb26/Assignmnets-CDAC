#include<iostream>
using namespace std;

class Student{

    int rollNo;
    string name;
    float marks;

public:

    // Default constructor
    Student(){
        rollNo = 0;
        name = "Unknown";
        marks = 0;
    }

    // Parameterized constructor
    Student(int r,string n,float m){
        rollNo = r;
        name = n;
        marks = m;
    }

    // Using this pointer
    Student(int rollNo,string name){
        this->rollNo = rollNo;
        this->name = name;
    }

    void display(){
        cout<<rollNo<<" "<<name<<" "<<marks<<endl;
    }

};

int main(){

    Student s1;
    Student s2(1,"Rahul",85);
    Student s3(2,"Anita",90);

    s1.display();
    s2.display();
    s3.display();

}








